# --- Core Framework Settings ---
PROJECT_NAME="AI Video Generator API"
VERSION="1.0.0"
API_PREFIX="/api/v1"

# --- Database Setup ---
# 1) 로컬 개발 및 디버깅 시 (Local Postgres)
DATABASE_URL="postgresql+asyncpg://ai_user:ai_password@localhost:5432/video_ai_db"
# 2) 도커 컴포즈로 실행 시 (Docker Compose 내부 네트워크용)
# DATABASE_URL="postgresql+asyncpg://ai_user:ai_password@db:5432/video_ai_db"

# --- JWT Authentication Settings ---
# 임의의 안전한 256비트 Hex 키를 사용해야 합니다. (예: openssl rand -hex 32)
JWT_SECRET_KEY="your-super-secret-jwt-key-here"
JWT_ALGORITHM="HS256"

# --- AI API Keys ---
# Gemini 및 LLM API 키 설정
LLM_API_KEY="your-gemini-api-key-here"
GEMINI_API_KEY="your-gemini-api-key-here"